# Application
APP_NAME=GamuCare AI
APP_ENV=development
LOG_LEVEL=INFO
LOG_FILE=/var/log/gamucare/api.jsonl
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
SEED_ON_STARTUP=true

# PostgreSQL
POSTGRES_DB=gamucare
POSTGRES_USER=gamucare
POSTGRES_PASSWORD=gamucare_dev_password
DATABASE_URL=postgresql+psycopg://gamucare:gamucare_dev_password@postgres:5432/gamucare

# Authentication - change before any public deployment
JWT_SECRET=change-this-local-secret-before-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
REFRESH_COOKIE_NAME=gamucare_refresh
REFRESH_COOKIE_SECURE=false
REFRESH_COOKIE_SAMESITE=lax
MAX_FAILED_LOGIN_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15
PASSWORD_MIN_LENGTH=12

# Ollama
OLLAMA_URL=http://ollama:11434
OLLAMA_BASE_MODEL=llama3.2:3b
OLLAMA_CHAT_MODEL=gamucare-llm
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_CONTEXT_LENGTH=4096

# Qdrant / RAG
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=gamucare_knowledge
RAG_MIN_SCORE=0.42
RAG_CANDIDATE_K=24
RAG_TOP_K=6
RAG_CLINICAL_TOP_K=12
RAG_ALERT_TOP_K=8
RAG_DOCUMENTS_PATH=/app/data/rag
RAG_EXTERNAL_DOCUMENTS_PATH=/app/data/rag_external
RAG_SOURCE_MANIFEST=/app/data/rag_sources/sources.json
RAG_SOURCE_MAX_BYTES=26214400
RAG_EVALUATION_DATASET=/app/data/evaluation/rag_cases_v2.json
SYSTEM_ACCEPTANCE_DATASET=/app/data/evaluation/acceptance_criteria_v1.json
ALERT_EVALUATION_DATASET=/app/data/evaluation/alert_cases_v1.json
QUALITY_REPORTS_PATH=/app/data/reports
QUALITY_BASE_URL=http://localhost:8000

# Frontend / CORS
CORS_ORIGINS=["http://localhost:8080","http://localhost:5173"]
VITE_API_URL=/api/v1
VITE_APP_ENV=demo

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=gamucare

# Cuenta tecnica local (el script no modifica la contrasena si el usuario ya existe)
TECHNICAL_USER_EMAIL=technical@gamucare.local
TECHNICAL_INITIAL_PASSWORD=GamuCare123!
